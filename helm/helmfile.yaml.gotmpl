repositories:
  - name: bitnami
    url: https://charts.bitnami.com/bitnami
  - name: prometheus-community
    url: https://prometheus-community.github.io/helm-charts
  - name: acr
    url: oci://{{ .Values.acrLoginServer }}/helm
    oci: true

helmfiles:
  - environments/azure/values/helmfile.yaml
